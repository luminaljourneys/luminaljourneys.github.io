rules_version = '2';
/**
 * firestore.rules — Luminal Journeys
 *
 * Security model:
 *   - Public website content (content_edits, pages, form config, meta) → anyone can READ
 *   - Writes to any content → must be a verified, authorized editor
 *   - authorized_editors list → only readable by signed-in + verified users (not public)
 *   - Intake submissions → anyone can CREATE (public form), only editors can READ/MANAGE
 *   - Notes, publish history → editors only
 *   - Everything else → deny
 *
 * "Authorized editor" = Firebase Auth user whose verified email is in
 *   site_config/authorized_editors { emails: [...] }
 *
 * Deploy: firebase deploy --only firestore:rules
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: signed in with a valid email ────────────────────────────────
    // Note: email_verified is intentionally NOT required here.
    // Google Sign-In and Email Link both produce verified sessions,
    // but Firebase token claims can be stale on first request after sign-in.
    // The authorized_editors check in isAuthorizedEditor() is the real gate.
    function isSignedIn() {
      return request.auth != null
          && request.auth.token.email != null;
    }

    // ── Helper: the admin@luminaljourneys.com service account ────────────────
    // Used by the password-login ("admin" / VITE_EDIT_PASSWORD) path.
    // Hardcoded so it bypasses the Firestore authorized_editors lookup —
    // no need to add it to the list manually in the Console.
    function isAdminServiceAccount() {
      return request.auth != null
          && request.auth.token.email == 'admin@luminaljourneys.com';
    }

    // ── Helper: signed-in AND email is in the authorized_editors list ────────
    // This check runs server-side on every write — cannot be bypassed from client.
    // Admin service account is always considered an authorized editor.
    function isAuthorizedEditor() {
      return isAdminServiceAccount()
          || (isSignedIn()
              && exists(/databases/$(database)/documents/site_config/authorized_editors)
              && request.auth.token.email in
                 get(/databases/$(database)/documents/site_config/authorized_editors).data.emails);
    }

    // ── site_config/meta ─────────────────────────────────────────────────────
    // Public read: "Last saved by" is shown on the public site.
    match /site_config/meta {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }

    // ── site_config/authorized_editors ───────────────────────────────────────
    // NOT publicly readable — requires sign-in + verified email.
    // Prevents anonymous actors from enumerating who has editor access.
    match /site_config/authorized_editors {
      allow read:  if isSignedIn();
      allow write: if isAuthorizedEditor();
    }

    // ── site_config/form_staging + form_production ───────────────────────────
    // Intake form config is public (drives the public intake form).
    match /site_config/form_staging {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }
    match /site_config/form_production {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }

    // ── Content edits (public website copy) ──────────────────────────────────
    match /content_edits_staging/{docId} {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }
    match /content_edits_production/{docId} {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }

    // ── Dynamic pages ─────────────────────────────────────────────────────────
    match /pages_staging/{docId} {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }
    match /pages_production/{docId} {
      allow read:  if true;
      allow write: if isAuthorizedEditor();
    }

    // ── Publish history ───────────────────────────────────────────────────────
    match /publish_history/{docId} {
      allow read, write: if isAuthorizedEditor();
    }

    // ── Collaborative notes ───────────────────────────────────────────────────
    match /page_notes/{docId} {
      allow read, write: if isAuthorizedEditor();
    }

    // ── Intake form submissions ───────────────────────────────────────────────
    // Anyone can submit the public intake form (create only).
    // Only authorized editors can read, manage, or delete submissions.
    match /intake_submissions/{docId} {
      allow create:               if true;
      allow read, update, delete: if isAuthorizedEditor();
    }

    // ── Editing locks (real-time collaborative presence) ─────────────────────
    // Authorized editors can read all locks to see who is editing what.
    // Any authorized editor can write/delete any lock (needed to release
    // stale locks if original editor disconnects).
    match /editing_locks/{lockId} {
      allow read, write: if isAuthorizedEditor();
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    // Any collection or document not explicitly listed above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
